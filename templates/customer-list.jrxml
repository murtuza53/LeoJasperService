<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="customer-list" pageWidth="595" pageHeight="842" columnWidth="535"
              leftMargin="30" rightMargin="30" topMargin="30" bottomMargin="30">

    <field name="id"          class="java.lang.String"/>
    <field name="name"        class="java.lang.String"/>
    <field name="email"       class="java.lang.String"/>
    <field name="country"     class="java.lang.String"/>
    <field name="signup_date" class="java.lang.String"/>

    <title>
        <band height="44">
            <staticText>
                <reportElement x="0" y="0" width="535" height="26"/>
                <textElement><font size="18" isBold="true"/></textElement>
                <text><![CDATA[Customer List]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="26" width="535" height="14"/>
                <textElement><font size="9" isItalic="true"/></textElement>
                <textFieldExpression><![CDATA["Generated " + new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="22">
            <staticText>
                <reportElement x="0" y="0" width="50" height="20"
                               backcolor="#333333" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[ ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="50" y="0" width="150" height="20"
                               backcolor="#333333" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[ Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="200" y="0" width="195" height="20"
                               backcolor="#333333" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[ Email]]></text>
            </staticText>
            <staticText>
                <reportElement x="395" y="0" width="80" height="20"
                               backcolor="#333333" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[ Country]]></text>
            </staticText>
            <staticText>
                <reportElement x="475" y="0" width="60" height="20"
                               backcolor="#333333" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[ Joined]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="18">
            <textField>
                <reportElement x="0" y="0" width="50" height="18"/>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="50" y="0" width="150" height="18"/>
                <textFieldExpression><![CDATA[$F{name}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="200" y="0" width="195" height="18"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{email}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="395" y="0" width="80" height="18"/>
                <textFieldExpression><![CDATA[$F{country}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="475" y="0" width="60" height="18"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{signup_date}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="20">
            <textField>
                <reportElement x="0" y="5" width="535" height="14"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>
</jasperReport>
