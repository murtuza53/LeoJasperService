<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="tax-invoice-1"
              pageWidth="595" pageHeight="842" columnWidth="535"
              leftMargin="30" rightMargin="30" topMargin="30" bottomMargin="30">

    <parameter name="INVOICE_NUMBER" class="java.lang.String"/>
    <parameter name="INVOICE_DATE" class="java.lang.String"/>
    <parameter name="TRN_NUMBER" class="java.lang.String"/>
    <parameter name="SENDER_NAME" class="java.lang.String"/>
    <parameter name="SENDER_ADDRESS" class="java.lang.String"/>
    <parameter name="SENDER_CR_NUMBER" class="java.lang.String"/>
    <parameter name="CUSTOMER_NAME" class="java.lang.String"/>
    <parameter name="CUSTOMER_ADDRESS" class="java.lang.String"/>
    <parameter name="CUSTOMER_TRN" class="java.lang.String"/>
    <parameter name="SUBTOTAL" class="java.lang.Double"/>
    <parameter name="TOTAL_VAT" class="java.lang.Double"/>
    <parameter name="GRAND_TOTAL" class="java.lang.Double"/>
    <parameter name="AMOUNT_IN_WORDS" class="java.lang.String"/>
    <parameter name="BANK_NAME" class="java.lang.String"/>
    <parameter name="ACCOUNT_NAME" class="java.lang.String"/>
    <parameter name="IBAN" class="java.lang.String"/>

    <field name="description" class="java.lang.String"/>
    <field name="quantity" class="java.lang.Integer"/>
    <field name="unit_price" class="java.lang.Double"/>
    <field name="vat_percentage" class="java.lang.String"/>
    <field name="vat_amount" class="java.lang.Double"/>
    <field name="total_item_amount" class="java.lang.Double"/>

    <title>
        <band height="62">
            <staticText>
                <reportElement x="0" y="0" width="200" height="40" forecolor="#0056B3"/>
                <textElement>
                    <font size="28" isBold="true"/>
                </textElement>
                <text><![CDATA[TAX INVOICE]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="40" width="200" height="20"/>
                <textElement>
                    <font size="14"/>
                </textElement>
                <text><![CDATA[فاتورة ضريبية]]></text>
            </staticText>
            <staticText>
                <reportElement x="350" y="0" width="80" height="15"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[INVOICE NO:]]></text>
            </staticText>
            <textField>
                <reportElement x="430" y="0" width="105" height="15"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{INVOICE_NUMBER}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="350" y="15" width="80" height="15"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[DATE:]]></text>
            </staticText>
            <textField>
                <reportElement x="430" y="15" width="105" height="15"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{INVOICE_DATE}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="350" y="30" width="80" height="15"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[TRN:]]></text>
            </staticText>
            <textField>
                <reportElement x="430" y="30" width="105" height="15"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{TRN_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <pageHeader>
        <band height="92">
            <staticText>
                <reportElement x="0" y="0" width="250" height="15" forecolor="#0056B3"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[FROM / من]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="20" width="250" height="15"/>
                <textElement>
                    <font size="12" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{SENDER_NAME}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="35" width="250" height="40"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{SENDER_ADDRESS}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="75" width="250" height="15"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{SENDER_CR_NUMBER}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="285" y="0" width="250" height="15" forecolor="#0056B3"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[BILL TO / فاتورة الى]]></text>
            </staticText>
            <textField>
                <reportElement x="285" y="20" width="250" height="15"/>
                <textElement>
                    <font size="12" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{CUSTOMER_NAME}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="285" y="35" width="250" height="40"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{CUSTOMER_ADDRESS}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="285" y="75" width="250" height="15"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{CUSTOMER_TRN}]]></textFieldExpression>
            </textField>
        </band>
    </pageHeader>

    <columnHeader>
        <band height="22">
            <staticText>
                <reportElement x="0" y="0" width="200" height="20"/>
                <textElement textAlignment="Left">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[DESCRIPTION / الوصف]]></text>
            </staticText>
            <staticText>
                <reportElement x="200" y="0" width="40" height="20"/>
                <textElement textAlignment="Center">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[QTY]]></text>
            </staticText>
            <staticText>
                <reportElement x="240" y="0" width="80" height="20"/>
                <textElement textAlignment="Right">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[UNIT PRICE]]></text>
            </staticText>
            <staticText>
                <reportElement x="320" y="0" width="50" height="20"/>
                <textElement textAlignment="Center">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[VAT %]]></text>
            </staticText>
            <staticText>
                <reportElement x="370" y="0" width="80" height="20"/>
                <textElement textAlignment="Right">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[VAT AMT]]></text>
            </staticText>
            <staticText>
                <reportElement x="450" y="0" width="85" height="20"/>
                <textElement textAlignment="Right">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[TOTAL (BHD)]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="22">
            <textField>
                <reportElement x="0" y="0" width="200" height="18"/>
                <textElement textAlignment="Left">
                </textElement>
                <textFieldExpression><![CDATA[$F{description}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0">
                <reportElement x="200" y="0" width="40" height="18"/>
                <textElement textAlignment="Center">
                </textElement>
                <textFieldExpression><![CDATA[$F{quantity}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.000">
                <reportElement x="240" y="0" width="80" height="18"/>
                <textElement textAlignment="Right">
                </textElement>
                <textFieldExpression><![CDATA[$F{unit_price}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="320" y="0" width="50" height="18"/>
                <textElement textAlignment="Center">
                </textElement>
                <textFieldExpression><![CDATA[$F{vat_percentage}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.000">
                <reportElement x="370" y="0" width="80" height="18"/>
                <textElement textAlignment="Right">
                </textElement>
                <textFieldExpression><![CDATA[$F{vat_amount}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.000">
                <reportElement x="450" y="0" width="85" height="18"/>
                <textElement textAlignment="Right">
                </textElement>
                <textFieldExpression><![CDATA[$F{total_item_amount}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="232">
            <staticText>
                <reportElement x="0" y="0" width="250" height="15" forecolor="#0056B3"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[PAYMENT TERMS / شروط الدفع]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="20" width="250" height="15"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <text><![CDATA[• Net 30 days from invoice date.]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="35" width="250" height="15"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <text><![CDATA[• Please include Invoice No. in payment reference.]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="50" width="250" height="15"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <text><![CDATA[• All bank charges are to be borne by the remitter.]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="75" width="250" height="15" forecolor="#0056B3"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[BANK DETAILS / تفاصيل البنك]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="90" width="250" height="15"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{BANK_NAME}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="105" width="250" height="15"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ACCOUNT_NAME}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="120" width="250" height="15"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{IBAN}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="300" y="0" width="150" height="15"/>
                <textElement textAlignment="Right">
                    <font size="10"/>
                </textElement>
                <text><![CDATA[Subtotal / المجموع الفرعي]]></text>
            </staticText>
            <textField pattern="#,##0.000">
                <reportElement x="450" y="0" width="85" height="15"/>
                <textElement textAlignment="Right">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{SUBTOTAL}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="300" y="20" width="150" height="15"/>
                <textElement textAlignment="Right">
                    <font size="10"/>
                </textElement>
                <text><![CDATA[Total VAT / إجمالي الضريبة]]></text>
            </staticText>
            <textField pattern="#,##0.000">
                <reportElement x="450" y="20" width="85" height="15"/>
                <textElement textAlignment="Right">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{TOTAL_VAT}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="300" y="50" width="150" height="20" forecolor="#0056B3"/>
                <textElement textAlignment="Right">
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[TOTAL BHD / الإجمالي]]></text>
            </staticText>
            <textField pattern="#,##0.000">
                <reportElement x="450" y="50" width="85" height="20" forecolor="#0056B3"/>
                <textElement textAlignment="Right">
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{GRAND_TOTAL}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="300" y="80" width="235" height="30"/>
                <textElement textAlignment="Left">
                    <font size="8" isItalic="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{AMOUNT_IN_WORDS}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="300" y="200" width="235" height="15"/>
                <textElement textAlignment="Center">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Authorized Signatory]]></text>
            </staticText>
            <staticText>
                <reportElement x="300" y="215" width="235" height="15"/>
                <textElement textAlignment="Center">
                    <font size="10"/>
                </textElement>
                <text><![CDATA[التوقيع المعتمد]]></text>
            </staticText>
        </band>
    </summary>

</jasperReport>
